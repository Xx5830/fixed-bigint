    int2025_t e = from_string("12345678901234567890");
    EXPECT_TRUE(d == e);
}

TEST(Equality, DifferentLargeNumbers) {
    int2025_t d = from_string("12345678901234567890");
    int2025_t f = from_string("12345678901234567891");
    EXPECT_FALSE(d == f);
}


